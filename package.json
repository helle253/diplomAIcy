{
  "name": "diplomaicy",
  "version": "0.1.0",
  "description": "Agent-oriented Diplomacy client with spectator UI",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "postinstall": "playwright install --with-deps chromium",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:e2e": "vite build && playwright test",
    "test:e2e:update": "vite build && playwright test --update-snapshots",
    "test:watch": "vitest",
    "start": "vite build && tsx --env-file=.env src/ui/server.ts",
    "dev": "concurrently -k -n tsc,vite,server \"tsc --watch --preserveWatchOutput\" \"vite\" \"tsx --watch --env-file=.env src/ui/server.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx --watch src/ui/server.ts",
    "lint": "eslint src/ .claude/skills/",
    "format": "prettier --write 'src/**/*.{ts,js,css,html}' '.claude/skills/**/*.ts'",
    "agent": "tsx src/agent/remote/run.ts",
    "start:remote": "DIPLOMAICY_CONFIG=diplomaicy.config.remote.json yarn start",
    "play:llm": "vite build && bash scripts/play-llm.sh",
    "play:random": "AGENT_TYPE=random vite build && bash scripts/play-llm.sh",
    "play:mixed": "AGENT_CONFIG=diplomaicy.config.mixed.json AGENT_TYPE= vite build && bash scripts/play-llm.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/eventsource": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@trpc/client": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "eventsource": "^4.1.0",
    "express": "^5.2.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
