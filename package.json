{
  "name": "diplomaicy",
  "version": "0.1.0",
  "description": "Agent-oriented Diplomacy client with spectator UI",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsc && vite build && node --env-file=.env dist/ui/server.js",
    "dev": "tsc && concurrently -k -n tsc,vite,server \"tsc --watch --preserveWatchOutput\" \"vite\" \"node --watch --env-file=.env dist/ui/server.js\"",
    "dev:client": "vite",
    "dev:server": "tsc && node --watch --env-file=.env dist/ui/server.js",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,js,css,html}'"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ws": "^8.19.0"
  }
}
